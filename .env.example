# === Docker 部署环境变量 ===

# 前端构建时需要的 API 地址 (宿主机 IP 或域名 + 端口)
# 【重要】此变量在 docker build 阶段被硬编码进前端产物，运行时修改无效
# 部署到服务器供他人访问时，必须在执行 docker compose up --build 前设置为对外可达的地址
# 例如: NEXT_PUBLIC_API_URL=http://your-server-ip-or-domain:18000
NEXT_PUBLIC_API_URL=http://localhost:18000

# 用于 docker-compose 变量替换（用于排障/验证），不影响前端构建产物
# NEXT_PUBLIC_API_URL 已在构建阶段硬编码进前端，修改此值不会影响客户端请求地址
SERVER_IP=localhost

# === 外部服务配置 (传递给 backend 容器) ===

# RAG 服务地址 (可选，留空则禁用 RAG 功能；填写占位地址会导致请求超时约 60s)
RAG_SERVICE_URL=

# HuggingFace Token (可选，用于下载模型)
HF_TOKEN=hf_your_token_here

