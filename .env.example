# === Docker 部署环境变量 ===

# 前端构建时需要的 API 地址 (宿主机 IP 或域名 + 端口)
# 注意：默认的配置中前端运行在 13000 端口，后端映射在 18000 端口
NEXT_PUBLIC_API_URL=http://localhost:18000

# 后端运行时需要的服务器 IP (通常与上面一致)
# 用于前端容器运行时动态替换
SERVER_IP=localhost

# === 外部服务配置 (传递给 backend 容器) ===

# RAG 服务地址 (可选)
RAG_SERVICE_URL=http://your-rag-service:8000

# HuggingFace Token (可选，用于下载模型)
HF_TOKEN=hf_your_token_here

